{
  "name": "assawave-onchain",
  "version": "0.1.0",
  "description": "ASSA WAVE Token (ASSA) smart contracts — veASSA zero-yield staking and BME burning pipeline",
  "license": "MIT",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:full:sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:full:mainnet": "hardhat run scripts/deploy.ts --network base",
    "deploy:token:sepolia": "hardhat run scripts/deploy-token.ts --network baseSepolia",
    "deploy:token:mainnet": "hardhat run scripts/deploy-token.ts --network base",
    "deploy:presale:sepolia": "hardhat run scripts/deploy-presale.ts --network baseSepolia",
    "deploy:presale:mainnet": "hardhat run scripts/deploy-presale.ts --network base",
    "deploy:migration:sepolia": "hardhat run scripts/deploy-migration.ts --network baseSepolia",
    "deploy:migration:mainnet": "hardhat run scripts/deploy-migration.ts --network base",
    "verify:sepolia": "hardhat verify --network baseSepolia",
    "verify:mainnet": "hardhat verify --network base",
    "node": "hardhat node",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "hardhat": "^2.22.0",
    "solidity-coverage": "^0.8.12",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@safe-global/protocol-kit": "^7.1.0",
    "@safe-global/safe-core-sdk-types": "^5.1.0"
  }
}
