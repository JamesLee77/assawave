# Reown / WalletConnect Cloud project id — https://dashboard.reown.com
# Client-side identifier, baked into the bundle at build time (NOT a secret).
# Add app.assawave.io to the project's Allowed Domains.
VITE_WALLETCONNECT_PROJECT_ID=

# Network selection: testnet (Base Sepolia, default) | mainnet (Base)
VITE_ENV=testnet

# Base RPC endpoints (defaults: public RPC)
VITE_BASE_RPC=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Backend API base URL (empty = same-origin / relative requests)
VITE_API_BASE_URL=
